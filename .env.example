# ===== คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง =====
# cp .env.example .env   (Windows: copy .env.example .env)
# *** ห้ามใส่ค่าจริงในไฟล์ .env.example นี้ — ใส่เฉพาะใน .env เท่านั้น ***

# Discord Webhook URL (สร้างจาก: Server Settings > Integrations > Webhooks > New Webhook > Copy URL)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxxx/yyyyyyyyyy
# OpenAI API Key (จาก https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- ค่าทางเลือก (ไม่ใส่ก็ได้ มีค่า default ให้แล้ว) -----
# โมเดล AI (ถูก+เร็ว). ใช้ gpt-4o-mini ได้ หรือรุ่นใหม่กว่าเช่น gpt-5.4-mini
OPENAI_MODEL=gpt-4o-mini
# รอบดึงข่าว (วินาที)
POLL_INTERVAL_SECONDS=60
# พิจารณาเฉพาะข่าวใหม่ภายในกี่ชั่วโมง
MAX_AGE_HOURS=6
# แจ้งเตือนสูงสุดต่อรอบ
MAX_ALERTS_PER_CYCLE=8
# แจ้งเฉพาะข่าวที่ impact ตั้งแต่ระดับนี้ขึ้นไป: Low | Medium | High
#   Medium = ตัดข่าว Low ทิ้ง (ค่าเริ่มต้น) | High = เฉพาะข่าวแรง (เงียบสุด)
ALERT_MIN_IMPACT=Medium
# กันข่าวเดียวกันจากหลายสำนักเด้งซ้ำ ภายในกี่ชั่วโมง (เพิ่มเลข = เงียบขึ้น)
DEDUP_TITLE_HOURS=6
# ที่อยู่ไฟล์ DB — บน Cloud ให้ชี้ persistent disk เช่น /data/seen_news.db
DB_PATH=seen_news.db
